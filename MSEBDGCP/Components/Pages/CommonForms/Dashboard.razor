@page "/dashboard"

@using Radzen
@using Radzen.Blazor

@* @using System.Globalization *@

<h3>Dashboard</h3>


<RadzenCard Style="margin-bottom:10px; background-color:#f3f6f9;" class="rz-shadow-4">
    <div class="row">
        <div class="col-md-5">
            <RadzenDropDown @bind-Value="Request.campId"
                            Data="_CampDetailsList"
                            TextProperty="CampNameBn"
                            ValueProperty="Id"
                            Placeholder="Select Camp"
                            Style="width:100%" AllowClear=true/>
        </div>

@*         <div class="col-md-3">
            <RadzenDropDown @bind-Value="Request.unitCommitteeId"
                            Data="_UnitCommitteList"
                            TextProperty="UnitCommitteeNameBn"
                            ValueProperty="UnitCommitteeId"
                            Placeholder="Select Unit"
                            Style="width:100%" /> 
        </div> *@

        <div class="col-md-2">
            <RadzenDatePicker @bind-Value="Request.startDate" Placeholder="Start Date" Style="width:100%" DateFormat="dd-MM-yyyy" />
        </div>

        <div class="col-md-2">
            <RadzenDatePicker @bind-Value="Request.endDate" Placeholder="End Date" Style="width:100%" DateFormat="dd-MM-yyyy" />
        </div>

        <div class="col-md-2">
            <RadzenButton Text="Filter" Click="@OnFilterClicked" Style="width:100%"/>
        </div>
    </div>
</RadzenCard>


@if (summary != null)
{
    <RadzenRow Style="margin-bottom:12px;">
        <RadzenColumn Size="4">
            <RadzenCard Style="background-color:#f3f6f9" class="rz-shadow-4"><h6>Total</h6><h2>@summary.Total</h2></RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="4" Style="background-color:#f3f6f9">
            <RadzenCard Style="background-color:#f3f6f9" class="rz-shadow-4"><h6>Male</h6><h2>@summary.Male</h2></RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="4" Style="background-color:#f3f6f9">
            <RadzenCard Style="background-color:#f3f6f9" class="rz-shadow-4"><h6>Female</h6><h2>@summary.Female</h2></RadzenCard>
        </RadzenColumn>
@*         <RadzenColumn Size="3" Style="background-color:#f3f6f9">
            <RadzenCard Style="background-color:#f3f6f9" class="rz-shadow-4"><h6>Other</h6><h2>@summary.Other</h2></RadzenCard>
        </RadzenColumn> *@
    </RadzenRow>
}

<!-- Summary cards -->

<RadzenCard Style="margin-bottom:10px; background-color:#f3f6f9;" class="rz-shadow-4">
    <RadzenRow>
        <RadzenColumn Size="12">
                <h5>Blood Group Distribution</h5>
                <RadzenChart SeriesClick=@OnSeriesClick>
                    <RadzenPieSeries Data="@summary.BloodGroups" Title="Total" CategoryProperty="BloodGroup" ValueProperty="Total">
                        <RadzenSeriesDataLabels Visible="@showDataLabels" />
                    </RadzenPieSeries>
                </RadzenChart>
        </RadzenColumn>
    </RadzenRow>
</RadzenCard>

<RadzenCard Style="margin-bottom:10px; background-color:#f3f6f9;" class="rz-shadow-4">
    <RadzenRow>
        <RadzenColumn Size="12">
            <h5>Monthly View</h5>
            <RadzenChart>
                <RadzenColumnSeries Data="@trendSeries" CategoryProperty="Category" ValueProperty="Value" />
                <RadzenValueAxis Min="0" Max="100" Step="20" />
                <RadzenSeriesDataLabels Visible="true" />
            </RadzenChart>
        </RadzenColumn>
    </RadzenRow>
</RadzenCard>

<RadzenRow>


    @*  <RadzenColumn Size="6">
        <RadzenCard>
            <h5>Beneficiaries Trend (@(startDate?.ToString("yyyy-MM") ?? "auto") - @(endDate?.ToString("yyyy-MM") ?? "auto"))</h5>
            <RadzenChart Style="height:350px;" Data="@trendSeries">
                <RadzenLineSeries ValueProperty="Value" CategoryProperty="Category" />
                <RadzenCategoryAxis>
                    <RadzenCategoryAxisTitle Text="Month" />
                </RadzenCategoryAxis>
                <RadzenValueAxis>
                    <RadzenValueAxisTitle Text="Count" />
                </RadzenValueAxis>
            </RadzenChart>
        </RadzenCard>
    </RadzenColumn> *@
</RadzenRow>

