@* @page "/blood-group-update" *@

<RadzenTemplateForm Data="@_Beneficiary" TItem="Domain.CampsModels.DBModels.Beneficiary">
    <RadzenRow>
        <RadzenColumn>
            <RadzenStack>
                <RadzenRow AlignItems="AlignItems.Center" Style="padding-bottom:10px">
                    <RadzenColumn Size="12" SizeMD="10">
                        <RadzenTextBox @bind-Value="MobileNumber" Name="MobileNumber" Placeholder="Mobile No*"
                                       Style="height: 30px !important; font-size: 0.85rem !important;width:100%;" />
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="2">
                        <RadzenButton Text="" Icon="search"
                                      Click="@(args => GetBeneficiaryInfo())"
                                      ButtonStyle="ButtonStyle.Info" />
                    </RadzenColumn>
                </RadzenRow>
                @if (_Beneficiary.Id > 0)
                {
                    <RadzenRow Style="padding-bottom:10px">
                        @if (@_Beneficiary.FullName != null)
                        {
                            <RadzenColumn Size="12" SizeMD="4">
                                <RadzenLabel Text="@_Beneficiary.FullName" Style="font-weight:bold;"></RadzenLabel>
                            </RadzenColumn>
                        }
                        @if (@_Beneficiary.FatherName != null)
                        {
                            <RadzenColumn Size="12" SizeMD="4">
                                <RadzenLabel Text="@_Beneficiary.FatherName" Style="font-weight:bold;"></RadzenLabel>
                            </RadzenColumn>
                        }
                        @if (@_Beneficiary.Age != null)
                        {
                            <RadzenColumn Size="12" SizeMD="4">
                                <RadzenLabel Text="@_Beneficiary.Age" Style="font-weight:bold;"></RadzenLabel>
                            </RadzenColumn>
                        }
                    </RadzenRow>
                    <RadzenRow AlignItems="AlignItems.Center">
                        <RadzenColumn Size="12" SizeMD="6" Style="margin-right:4px">
                            <RadzenDropDown @bind-Value="_Beneficiary.BloodGroup"
                                            Data="@bloodGroupList"
                                            TextProperty="BlodGroupNameEn"
                                            ValueProperty="BloodGroupId"
                                            Placeholder="Select Blood Group *"
                                            Style="width:100%" 
                                            AllowClear="true"
                                            Name="BloodGroup" />
                            <RadzenRequiredValidator Component="BloodGroup" Text="Blood Group is required" Style="position: relative" />
                        </RadzenColumn>
                        <RadzenColumn Size="12" SizeMD="4" Style="padding-right:4px">
                            <RadzenButton Text="" Icon="save"
                                          Click="@(args => UpdateBloodGroup())"
                                          ButtonStyle="ButtonStyle.Success"
                                          ButtonType="ButtonType.Submit" />
                            <RadzenButton Text="" Icon="clear" Click="ClearForm"
                                          Shade="Shade.Lighter" ButtonStyle="ButtonStyle.Secondary" />
                            <RadzenButton Text="" Icon="logout" Click="CloseForm"
                                          Shade="Shade.Default" ButtonStyle="ButtonStyle.Secondary" />
                        </RadzenColumn>
                        <RadzenColumn Size="12" SizeMD="2" Style="margin-right:6px">
                            
                        </RadzenColumn>
                    </RadzenRow>
                }
             </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
</RadzenTemplateForm>

