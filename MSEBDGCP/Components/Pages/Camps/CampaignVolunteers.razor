@page "/campaign-volunteers"

<style>
    .campaign-volunteers-grid .rz-badge.active-status-badge {
        background: #198754 !important;
        border-color: #198754 !important;
        color: #ffffff !important;
        box-shadow: 0 8px 18px rgba(25, 135, 84, .22);
    }

    .campaign-action-button-soft {
        border-radius: 999px !important;
        border-width: 1px !important;
        box-shadow: none !important;
        transition: transform .2s ease, box-shadow .2s ease, filter .2s ease;
    }

    .campaign-action-button-soft:hover,
    .campaign-action-button-soft:focus {
        transform: translateY(-1px);
        box-shadow: 0 10px 20px rgba(49, 91, 75, .12) !important;
        filter: saturate(1.05);
    }

    .campaign-action-button-soft.qr-button {
        background: #eef8f1 !important;
        border-color: #cfe8d6 !important;
        color: #2f7a59 !important;
    }

    .campaign-action-button-soft.edit-button {
        background: #eef4ff !important;
        border-color: #cfdbf6 !important;
        color: #3563b6 !important;
    }

    .campaign-action-button-soft.delete-button {
        background: #fff1f1 !important;
        border-color: #f3caca !important;
        color: #c05a5a !important;
    }
</style>

<PageTitle>Campaign Volunteers</PageTitle>

<RadzenCard Style="border-radius:20px; box-shadow: 0 0 8px rgba(0,0,0,0.12); margin-bottom:20px;">
    <RadzenRow JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Gap="12px">
        <RadzenColumn Size="12" SizeMD="8">
            <RadzenText Text="Campaign Volunteers" TextStyle="TextStyle.H5" Style="font-weight:700; color:#193e91;" />
            <RadzenText Text="Manage the volunteer registry collected from the campaign volunteer form." TextStyle="TextStyle.Body2" Style="color:#6c757d;" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4" Style="text-align:right;">
            <RadzenButton Text="Create New" Icon="add_circle" Click="OpenCreateDialog" Class="msebdg-action-button" />
        </RadzenColumn>
    </RadzenRow>
</RadzenCard>

<RadzenCard Style="border-radius:20px; box-shadow: 0 0 8px rgba(0,0,0,0.10);">
    <RadzenDataGrid @ref="volunteerGrid" Data="@volunteers" TItem="Domain.CampsModels.RespDTO.CampaignVolunteerDto"
                    AllowFiltering="true" AllowSorting="true" AllowPaging="true" PageSize="10"
                    FilterMode="FilterMode.Advanced" Responsive="true" EmptyText="No volunteers found."
                    Class="rz-border-radius-2xl campaign-volunteers-grid">
        <Columns>
            <RadzenDataGridColumn TItem="Domain.CampsModels.RespDTO.CampaignVolunteerDto" Title="Photo" Width="90px" Filterable="false" Sortable="false">
                <Template Context="item">
                    <img src="@GetPhoto(item.PhotoLocation)" alt="@item.FullNameEn" style="width:48px; height:48px; border-radius:50%; object-fit:cover; border:2px solid #e7ecf5;" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="FullNameEn" Title="Name" />
            <RadzenDataGridColumn Property="BloodGroupName" Title="Blood Group" Width="120px" />
            <RadzenDataGridColumn Property="GenderName" Title="Gender" Width="110px" />
            <RadzenDataGridColumn Property="PhoneNumber" Title="Phone" Width="130px" />
            <RadzenDataGridColumn Property="VillageName" Title="Village" Width="140px" />
            <RadzenDataGridColumn Property="ThanaName" Title="Thana" Width="140px" />
            <RadzenDataGridColumn Property="ZillaName" Title="Zilla" Width="140px" />
            <RadzenDataGridColumn Property="DivisionName" Title="Division" Width="140px" />
            <RadzenDataGridColumn Property="BloodDonationsCount" Title="Donations" Width="110px" />
            <RadzenDataGridColumn Property="GroupingCampParticipationCount" Title="Camps" Width="90px" />
            <RadzenDataGridColumn Title="Status" Width="100px">
                <Template Context="item">
                    @if (item.Active)
                    {
                        <RadzenBadge Text="Active" Shade="Shade.Darker" BadgeStyle="BadgeStyle.Success" class="active-status-badge" />
                    }
                    else
                    {
                        <RadzenBadge Text="Inactive" BadgeStyle="BadgeStyle.Danger" />
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="Actions" Width="190px" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
                <Template Context="item">
                    <RadzenButton Icon="qr_code_2" Size="ButtonSize.Small" Class="campaign-action-button-soft qr-button" Click="@(args => ViewQrCode(item))" Style="margin-right:6px;" />
                    <RadzenButton Icon="edit" Size="ButtonSize.Small" Class="campaign-action-button-soft edit-button" Click="@(args => OpenEditDialog(item.VolunteerId))" Style="margin-right:6px;" />
                    <RadzenButton Icon="delete" Size="ButtonSize.Small" Class="campaign-action-button-soft delete-button" Click="@(args => DeleteVolunteer(item.VolunteerId, item.FullNameEn))" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenCard>
