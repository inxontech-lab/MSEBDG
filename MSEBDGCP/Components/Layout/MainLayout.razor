@inherits LayoutComponentBase

<HeadContent>
    <link href="css/app.css" rel="stylesheet" />
</HeadContent>

<RadzenComponents @rendermode="InteractiveAuto" />
@* <div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
