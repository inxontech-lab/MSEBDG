@page "/volunteers"
@layout Layout.VolunteerLayout
@using Domain.Core
@using Domain.CampsModels.RespDTO
@using Shared.VolunteerLinks
@inject Shared.CampsClient.Master.CampaignVolunteerService CampaignVolunteerService
@inject Shared.CampsClient.Master.CampaignVolunteerProfileService CampaignVolunteerProfileService
@inject IConfiguration Configuration

<PageTitle>Campaign Volunteers</PageTitle>

<style>
    .volunteer-page {
        min-height: calc(100vh - 180px);
    }

    .volunteer-hero {
        background: linear-gradient(135deg, rgba(255, 239, 241, .98) 0%, rgba(255, 247, 244, .97) 42%, rgba(240, 251, 245, .96) 100%);
        color: #7d1c22;
        border: 1px solid rgba(254, 0, 2, .10);
        border-radius: 24px;
        box-shadow: 0 18px 40px rgba(125, 28, 34, .08);
        padding: 3rem 2rem;
        margin-top: 7rem;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
    }

    .volunteer-hero::after {
        content: "";
        position: absolute;
        inset: auto -8% -35% auto;
        width: 240px;
        height: 240px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(0, 153, 73, .16) 0%, rgba(0, 153, 73, 0) 72%);
        pointer-events: none;
    }

    .volunteer-hero h1 {
        color: #7d1c22;
        scroll-margin-top: 11rem;
    }

    .volunteer-hero-copy {
        color: #6d5b5f;
    }

    .volunteer-loading {
        min-height: 40vh;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        align-items: center;
        padding-top: 2rem;
    }

    .volunteer-card-link {
        text-decoration: none;
        color: inherit;
        display: block;
        height: 100%;
    }

    .volunteer-card {
        border: 1px solid rgba(0, 153, 73, .14);
        border-radius: 24px;
        overflow: hidden;
        background: linear-gradient(135deg, rgba(255, 239, 241, .98) 0%, rgba(255, 247, 244, .97) 42%, rgba(240, 251, 245, .96) 100%);
        box-shadow: 0 16px 36px rgba(44, 122, 79, 0.12);
        transition: transform .25s ease, box-shadow .25s ease;
        height: 100%;
        position: relative;
        cursor: pointer;
    }

    .volunteer-card::before {
        content: "";
        position: absolute;
        inset: 0 0 auto 0;
        height: 5px;
        background: linear-gradient(90deg, rgba(255, 173, 181, .9) 0%, rgba(255, 220, 188, .95) 48%, rgba(125, 212, 161, .95) 100%);
    }

    .volunteer-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 22px 40px rgba(44, 122, 79, 0.18);
    }

    .volunteer-photo,
    .volunteer-photo-placeholder {
        width: 92px;
        height: 92px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .volunteer-photo {
        object-fit: cover;
        border: 4px solid rgba(239, 83, 80, .18);
        background: white;
    }

    .volunteer-photo-placeholder {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, rgba(255,235,238,.95), rgba(255,245,245,.95));
        border: 4px solid rgba(239, 83, 80, .16);
        color: #d32f2f;
        font-size: 2rem;
    }

    .volunteer-pill {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        background: rgba(255,255,255,.8);
        color: #9f1d20;
        border: 1px solid rgba(239, 83, 80, .12);
        padding: .35rem .75rem;
        border-radius: 999px;
        font-size: .85rem;
        font-weight: 600;
    }

    .volunteer-meta {
        color: #6c757d;
        font-size: .95rem;
        display: flex;
        align-items: flex-start;
        gap: .7rem;
    }

    .volunteer-meta i {
        width: 1rem;
        margin-top: .25rem;
    }

    .volunteer-name-bn {
        color: #7c7c89;
        font-weight: 500;
    }

    .volunteer-stat {
        background: rgba(255,255,255,.78);
        border-radius: 18px;
        padding: 1rem;
        border: 1px solid rgba(239, 83, 80, .10);
    }

    .volunteer-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1rem;
        color: #9f1d20;
        font-weight: 600;
    }
</style>

<div class="container-xxl py-5 volunteer-page">
    <div class="container">
        <div class="volunteer-hero">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <div class="d-inline-block rounded-pill bg-white text-primary py-1 px-3 mb-3">Volunteer Directory</div>
                    <h1 class="display-5 mb-3">Meet the volunteers supporting our blood grouping campaigns.</h1>
                    <p class="mb-0 fs-5 volunteer-hero-copy">Click any card to open the full volunteer profile, including the photo and complete registration information.</p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <div class="bg-white text-dark rounded-4 p-4 shadow-sm">
                        <div class="text-muted">Active Volunteers</div>
                        <div class="display-4 fw-bold text-primary">@volunteers.Count</div>
                        <div class="small text-muted">Updated from the campaign volunteer registry.</div>
                    </div>
                </div>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="volunteer-loading text-center">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 text-muted">Loading volunteers...</p>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(loadError))
        {
            <div class="alert alert-danger rounded-4">@loadError</div>
        }
        else if (volunteers.Count == 0)
        {
            <div class="alert alert-info rounded-4">No volunteers are available right now.</div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var volunteer in volunteers)
                {
                    <div class="col-lg-4 col-md-6 wow fadeInUp">
                        <a class="volunteer-card-link" href="@GetVolunteerDetailsUrl(volunteer.VolunteerId)">
                            <div class="card volunteer-card">
                                <div class="card-body p-4">
                                    <div class="d-flex align-items-center gap-3 mb-3">
                                        @if (!string.IsNullOrWhiteSpace(volunteer.PhotoDataUri))
                                        {
                                            <img src="@volunteer.PhotoDataUri" alt="@volunteer.FullNameEn" class="volunteer-photo" />
                                        }
                                        else
                                        {
                                            <div class="volunteer-photo-placeholder" aria-label="Volunteer photo unavailable">
                                                <i class="fa fa-user text-danger"></i>
                                            </div>
                                        }

                                        <div>
                                            <h5 class="mb-1">@volunteer.FullNameEn</h5>
                                            <div class="volunteer-name-bn">@volunteer.FullNameBn</div>
                                        </div>
                                    </div>

                                    <div class="d-flex flex-wrap gap-2 mb-3">
                                        <span class="volunteer-pill"><i class="fa fa-tint"></i>@volunteer.BloodGroupName</span>
                                        <span class="volunteer-pill"><i class="fa fa-user"></i>@volunteer.GenderName</span>
                                    </div>

                                    <div class="volunteer-meta mb-2">
                                        <i class="fa fa-map-marker-alt text-danger"></i>
                                        <span>@GetAddress(volunteer)</span>
                                    </div>
                                    <div class="volunteer-meta mb-2">
                                        <i class="fa fa-envelope text-primary"></i>
                                        <span>@(string.IsNullOrWhiteSpace(volunteer.Email) ? "No email provided" : volunteer.Email)</span>
                                    </div>
                                    <div class="volunteer-meta mb-3">
                                        <i class="fa fa-building text-primary"></i>
                                        <span>@(string.IsNullOrWhiteSpace(volunteer.UnitCommitteeName) ? "Unit committee not provided" : volunteer.UnitCommitteeName)</span>
                                    </div>

                                    <div class="row g-2 text-center">
                                        <div class="col-6">
                                            <div class="volunteer-stat">
                                                <div class="h4 mb-0 text-primary">@volunteer.BloodDonationsCount</div>
                                                <small class="text-muted">Blood Donations</small>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="volunteer-stat">
                                                <div class="h4 mb-0 text-primary">@volunteer.GroupingCampParticipationCount</div>
                                                <small class="text-muted">Campaigns Joined</small>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="volunteer-card-footer">
                                        <span>View full profile</span>
                                        <i class="fa fa-arrow-right"></i>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private bool isLoading = true;
    private string? loadError;
    private List<VolunteerCardViewModel> volunteers = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await CampaignVolunteerService.GetCampaignVolunteerListAsync(true);
            if (response?.RESPONSE_CODE == ConfigClass.SUCCESS && response.VolunteerList != null)
            {
                volunteers = response.VolunteerList
                    .Select(MapVolunteer)
                    .ToList();

                await EnrichVolunteerProfilesAsync(volunteers);
            }
            else
            {
                loadError = response?.RESPONSE_DESCRPTION ?? "Unable to load volunteers.";
            }
        }
        catch
        {
            loadError = "Unable to load volunteers.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task EnrichVolunteerProfilesAsync(List<VolunteerCardViewModel> volunteerCards)
    {
        var profileTasks = volunteerCards.Select(async volunteer =>
        {
            try
            {
                var profileResponse = await CampaignVolunteerProfileService.GetVolunteerProfileAsync(volunteer.VolunteerId);
                if (profileResponse?.RESPONSE_CODE != ConfigClass.SUCCESS || profileResponse.Volunteer == null)
                {
                    return;
                }

                var profile = profileResponse.Volunteer;
                volunteer.FullNameEn = profile.FullNameEn;
                volunteer.FullNameBn = profile.FullNameBn;
                volunteer.ThanaName = profile.ThanaName;
                volunteer.ZillaName = profile.ZillaName;
                volunteer.DivisionName = profile.DivisionName;
                volunteer.Email = profile.Email;
                volunteer.UnitCommitteeName = profile.UnitCommitteeName;
                volunteer.BloodDonationsCount = profile.BloodDonationsCount;
                volunteer.GroupingCampParticipationCount = profile.GroupingCampParticipationCount;
                volunteer.PhotoDataUri = BuildPhotoDataUri(profile.PhotoMimeType, profile.PhotoBase64);
            }
            catch
            {
                // Keep base volunteer list data when the profile service is unavailable.
            }
        });

        await Task.WhenAll(profileTasks);
    }

    private static VolunteerCardViewModel MapVolunteer(CampaignVolunteerDto volunteer)
    {
        return new VolunteerCardViewModel
        {
            VolunteerId = volunteer.VolunteerId,
            FullNameEn = volunteer.FullNameEn,
            FullNameBn = volunteer.FullNameBn,
            BloodGroupName = volunteer.BloodGroupName,
            GenderName = volunteer.GenderName,
            ThanaName = volunteer.ThanaName,
            ZillaName = volunteer.ZillaName,
            DivisionName = volunteer.DivisionName,
            Email = volunteer.Email,
            UnitCommitteeName = volunteer.UnitCommitteeName,
            BloodDonationsCount = volunteer.BloodDonationsCount,
            GroupingCampParticipationCount = volunteer.GroupingCampParticipationCount
        };
    }

    private static string GetAddress(VolunteerCardViewModel volunteer)
    {
        return string.Join(", ", new[] { volunteer.ThanaName, volunteer.ZillaName, volunteer.DivisionName }
            .Where(value => !string.IsNullOrWhiteSpace(value)));
    }

    private string GetVolunteerDetailsUrl(int volunteerId) => VolunteerPublicLinkEncoder.BuildVolunteerDetailsPath(volunteerId, Configuration);

    private static string? BuildPhotoDataUri(string? photoMimeType, string? photoBase64)
    {
        if (string.IsNullOrWhiteSpace(photoBase64))
        {
            return null;
        }

        return $"data:{(string.IsNullOrWhiteSpace(photoMimeType) ? "image/jpeg" : photoMimeType)};base64,{photoBase64}";
    }

    private sealed class VolunteerCardViewModel
    {
        public int VolunteerId { get; set; }
        public string FullNameEn { get; set; } = string.Empty;
        public string FullNameBn { get; set; } = string.Empty;
        public string BloodGroupName { get; set; } = string.Empty;
        public string GenderName { get; set; } = string.Empty;
        public string ThanaName { get; set; } = string.Empty;
        public string ZillaName { get; set; } = string.Empty;
        public string DivisionName { get; set; } = string.Empty;
        public string? Email { get; set; }
        public string? UnitCommitteeName { get; set; }
        public int BloodDonationsCount { get; set; }
        public int GroupingCampParticipationCount { get; set; }
        public string? PhotoDataUri { get; set; }
    }
}
