@page "/volunteers"
@using Domain.Core
@using Domain.CampsModels.RespDTO
@inject Shared.CampsClient.Master.CampaignVolunteerService CampaignVolunteerService

<PageTitle>Campaign Volunteers</PageTitle>

<style>
    .volunteer-page {
        min-height: calc(100vh - 180px);
    }

    .volunteer-hero {
        background: linear-gradient(135deg, rgba(25,62,145,.92), rgba(11,126,179,.82));
        color: white;
        border-radius: 24px;
        padding: 3rem 2rem;
        margin-top: 7rem;
        margin-bottom: 2rem;
    }

    .volunteer-hero h1 {
        scroll-margin-top: 11rem;
    }

    .volunteer-loading {
        min-height: 40vh;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        align-items: center;
        padding-top: 2rem;
    }

    .volunteer-card {
        border: 0;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 12px 28px rgba(25, 62, 145, 0.10);
        transition: transform .25s ease, box-shadow .25s ease;
        height: 100%;
    }

    .volunteer-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 18px 34px rgba(25, 62, 145, 0.18);
    }

    .volunteer-photo {
        width: 88px;
        height: 88px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid rgba(25,62,145,.12);
    }

    .volunteer-pill {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        background: #eef4ff;
        color: #193e91;
        padding: .35rem .75rem;
        border-radius: 999px;
        font-size: .85rem;
        font-weight: 600;
    }

    .volunteer-meta {
        color: #6c757d;
        font-size: .95rem;
    }
</style>

<div class="container-xxl py-5 volunteer-page">
    <div class="container">
        <div class="volunteer-hero">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <div class="d-inline-block rounded-pill bg-white text-primary py-1 px-3 mb-3">Volunteer Directory</div>
                    <h1 class="display-5 text-white mb-3">Meet the volunteers supporting our blood grouping campaigns.</h1>
                    <p class="mb-0 fs-5">This page highlights the campaign volunteers registered through the official volunteer form and grouped by their service areas across Bangladesh.</p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <div class="bg-white text-dark rounded-4 p-4 shadow-sm">
                        <div class="text-muted">Active Volunteers</div>
                        <div class="display-4 fw-bold text-primary">@volunteers.Count</div>
                        <div class="small text-muted">Updated from the campaign volunteer registry.</div>
                    </div>
                </div>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="volunteer-loading text-center">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 text-muted">Loading volunteers...</p>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(loadError))
        {
            <div class="alert alert-danger rounded-4">@loadError</div>
        }
        else if (volunteers.Count == 0)
        {
            <div class="alert alert-info rounded-4">No volunteers are available right now.</div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var volunteer in volunteers)
                {
                    <div class="col-lg-4 col-md-6 wow fadeInUp">
                        <div class="card volunteer-card">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <img src="@GetPhoto(volunteer.PhotoLocation)" alt="@volunteer.FullNameEn" class="volunteer-photo" />
                                    <div>
                                        <h5 class="mb-1">@volunteer.FullNameEn</h5>
                                        <div class="text-muted">@volunteer.FullNameBn</div>
                                    </div>
                                </div>

                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    <span class="volunteer-pill"><i class="fa fa-tint"></i>@volunteer.BloodGroupName</span>
                                    <span class="volunteer-pill"><i class="fa fa-user"></i>@volunteer.GenderName</span>
                                </div>

                                <div class="volunteer-meta mb-2"><i class="fa fa-phone-alt text-primary me-2"></i>@volunteer.PhoneNumber</div>
                                @if (!string.IsNullOrWhiteSpace(volunteer.WhatsAppNumber))
                                {
                                    <div class="volunteer-meta mb-2"><i class="fab fa-whatsapp text-success me-2"></i>@volunteer.WhatsAppNumber</div>
                                }
                                <div class="volunteer-meta mb-2"><i class="fa fa-map-marker-alt text-danger me-2"></i>@volunteer.VillageName, @volunteer.ThanaName, @volunteer.ZillaName, @volunteer.DivisionName</div>
                                <div class="volunteer-meta mb-2"><i class="fa fa-envelope text-primary me-2"></i>@(string.IsNullOrWhiteSpace(volunteer.Email) ? "No email provided" : volunteer.Email)</div>
                                <div class="volunteer-meta mb-3"><i class="fa fa-building text-primary me-2"></i>@(string.IsNullOrWhiteSpace(volunteer.UnitCommitteeName) ? "Unit committee not provided" : volunteer.UnitCommitteeName)</div>

                                <div class="row g-2 text-center">
                                    <div class="col-6">
                                        <div class="bg-light rounded-4 p-3">
                                            <div class="h4 mb-0 text-primary">@volunteer.BloodDonationsCount</div>
                                            <small class="text-muted">Blood Donations</small>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="bg-light rounded-4 p-3">
                                            <div class="h4 mb-0 text-primary">@volunteer.GroupingCampParticipationCount</div>
                                            <small class="text-muted">Campaigns Joined</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private bool isLoading = true;
    private string? loadError;
    private List<CampaignVolunteerDto> volunteers = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await CampaignVolunteerService.GetCampaignVolunteerListAsync(true);
            if (response?.RESPONSE_CODE == ConfigClass.SUCCESS && response.VolunteerList != null)
            {
                volunteers = response.VolunteerList;
            }
            else
            {
                loadError = response?.RESPONSE_DESCRPTION ?? "Unable to load volunteers.";
            }
        }
        catch
        {
            loadError = "Unable to load volunteers.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetPhoto(string? photoLocation)
    {
        return string.IsNullOrWhiteSpace(photoLocation) ? "images/cropped_circle_image.png" : photoLocation;
    }
}
