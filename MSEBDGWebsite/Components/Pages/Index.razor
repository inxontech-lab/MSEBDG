@page "/"

    <style>
        .brand-title {
            max-width: 65vw;
            overflow: hidden;
            text-overflow: ellipsis;
            text-shadow: 0 0 5px rgba(0,0,0,0.3); /* glow for visibility */
        }

        .home-header-link {
            color: #FF6F0F !important;
            font-weight: 600;
            text-shadow: 0 0 5px rgba(0,0,0,0.3);
        }

        .home-header-link:hover,
        .home-header-link:focus {
            color: #ff8c3a !important;
        }

        .home-header-action {
            color: #ffffff;
            border: 1px solid #FF6F0F;
            background: #FF6F0F;
            font-weight: 600;
            box-shadow: 0 10px 24px rgba(255, 111, 15, 0.28);
        }

        .home-header-action:hover,
        .home-header-action:focus {
            color: #ffffff;
            border-color: #ff8c3a;
            background: #ff8c3a;
        }

        .hero-patron-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 1.5rem;
        }

        .speaker-card {
            height: 100%;
            background: rgba(248, 248, 248, 0.95);
            border-radius: 18px;
            box-shadow: 0 12px 32px rgba(0,0,0,0.18);
            padding: 1.75rem;
            transition: all 0.3s ease;
            backdrop-filter: blur(4px);
        }

        .speaker-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 16px 36px rgba(0,0,0,0.22);
        }

        .speaker-card img {
            border-radius: 50%;
            width: 150px;
            height: 150px;
            object-fit: cover;
            border: 5px solid rgba(255, 111, 15, 0.15);
        }

        .speaker-card-label {
            display: inline-block;
            margin-bottom: 1rem;
            padding: 0.45rem 1rem;
            border-radius: 999px;
            background: rgba(255, 111, 15, 0.12);
            color: #FF6F0F;
            font-size: 0.95rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .fade-logo {
            transition: opacity 1.5s ease-in-out;
        }

        .dim {
            opacity: 0.4;
        }

        #header-carousel,
            .carousel-inner,
            .carousel-item {
                height: 100vh;
            }

            .carousel-video {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        @media (max-width: 991.98px) {
            .hero-patron-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>

<script>
    setInterval(() => {
        const logo = document.querySelector(".fade-logo");
        logo?.classList.toggle("dim");
    }, 1500);
</script>

