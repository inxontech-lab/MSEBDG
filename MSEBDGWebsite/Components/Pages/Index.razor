        }

        .fade-logo {
            transition: opacity 1.5s ease-in-out;
        }

        .dim {
            opacity: 0.4;
        }

        .speaker-card {
            background: #f8f8f8;
            border-radius: 10px;
            box-shadow: 0 3px 15px rgba(0,0,0,0.08);
            padding: 30px;
            transition: all 0.3s ease;
        }

            .speaker-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 5px 20px rgba(0,0,0,0.12);
            }

            .speaker-card img {
                border-radius: 50%;
                width: 150px;
                height: 150px;
                object-fit: cover;
            }
            #header-carousel,
            .carousel-inner,
            .carousel-item {
                height: 100vh;
            }

            .carousel-video {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }
    </style>

    <script>
        setInterval(() => {
            const logo = document.querySelector(".fade-logo");
            logo.classList.toggle("dim");
        }, 1500);
    </script>
